# Required — powers ChatGPT + GPT-4o-mini analysis layer
OPENAI_API_KEY=sk-...

# Required — powers Llama 3, Llama 4, Qwen 3 (all free)
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional — MongoDB Atlas for persistent scan history
# Without this, history is saved to data/results.json (local only)
# Get a free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/

# Optional
PORT=3000
